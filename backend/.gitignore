# Python bytecode & cache
__pycache__/
*.py[cod]
*$py.class
*.pyd

# Virtual Environments
venv/
.venv/
env/
ENV/
bin/
lib/
include/
pip-selfcheck.json

# Environment Configuration
.env
.flaskenv
*.env.local

# Databases & SQLite
*.db
*.sqlite
*.sqlite3

# Logs
logs/
*.log

# Jupyter Notebook Checkpoints
.ipynb_checkpoints/

# IDEs & OS Files
.vscode/
.idea/
.DS_Store
Thumbs.db
