# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Build outputs
dist/
dist-ssr/
build/
out/

# Logs & Debugging
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment Configuration
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.local

# Testing & Coverage
coverage/
.nyc_output/

# Editor & System Files
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
